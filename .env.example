# --- 인증 (멀티 유저) ---
# 세션 JWT 서명 키. 필수. 생성: openssl rand -base64 32
# 로컬과 Vercel 에 동일 값을 넣어야 토큰이 양쪽에서 검증됩니다.
AUTH_SECRET=

# (레거시) 전역 단일 비밀번호 게이트. 멀티유저 전환 후 미사용 — 비워둬도 됩니다.
LOGIN_PASSWORD=

# --- Claude (서버 측 PDF 파싱 · 약기법 LLM 판정) ---
# 사용자가 시트 생성용으로 직접 입력하는 키는 환경변수가 아니라 요청 본문으로 받습니다.
CLAUDE_ADMIN_KEY=sk-ant-...

# --- Vercel Postgres ---
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# --- Vercel Blob (PDF 저장) ---
BLOB_READ_WRITE_TOKEN=

# --- Qoo10 파싱 옵션 ---
# Tier 2 (Playwright) 사용 시 일본 IP 프록시 URL (선택)
QOO10_PROXY_URL=

# Tier 2 헤드리스 브라우저 실행 파일 경로 오버라이드 (선택).
#  - 로컬: 비워두면 설치된 시스템 Google Chrome 을 자동 사용.
#  - Vercel/서버리스: 비워두면 @sparticuz/chromium 번들 바이너리를 자동 사용
#    (VERCEL 환경변수로 자동 감지 — 별도 설정 불필요).
#  - 특정 Chrome/Chromium 경로를 강제하려면 여기에 절대경로를 넣으세요.
PLAYWRIGHT_CHROMIUM_PATH=

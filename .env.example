# --- 앱 게이트 ---
# brifbyai 전역 비밀번호 (사내 도구). 비워두면 게이트가 비활성화됩니다 (로컬 개발용).
LOGIN_PASSWORD=

# --- Claude (서버 측 PDF 파싱 · 약기법 LLM 판정) ---
# 사용자가 시트 생성용으로 직접 입력하는 키는 환경변수가 아니라 요청 본문으로 받습니다.
CLAUDE_ADMIN_KEY=sk-ant-...

# --- Vercel Postgres ---
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# --- Vercel Blob (PDF 저장) ---
BLOB_READ_WRITE_TOKEN=

# --- Qoo10 파싱 옵션 ---
# Tier 2 (Playwright) 사용 시 일본 IP 프록시 URL (선택)
QOO10_PROXY_URL=
